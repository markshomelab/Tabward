{
  "manifest_version": 3,
  "name": "Tabward",
  "version": "1.0.0",
  "description": "Automatically focuses new tabs when they are opened. Click the toolbar icon to enable or disable.",
  "browser_specific_settings": {
    "gecko": {
      "id": "tabward@example.com",
      "strict_min_version": "115.0"
    }
  },
  "permissions": [
    "tabs",
    "storage"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Tabward: Click to toggle"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
